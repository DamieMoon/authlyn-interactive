SURREAL_URL=ws://127.0.0.1:8000
SURREAL_NS=authlyn
SURREAL_DB=dev
SURREAL_USER=root
SURREAL_PASS=root

# Web Push (#30 background notifications). Generate a keypair ONCE with:
#   npx web-push generate-vapid-keys
# Both values are base64url-unpadded; the public key doubles as the browser's
# applicationServerKey. VAPID_SUBJECT must be a mailto: or https: URL. Leave the
# keys blank to disable push entirely (the app runs fine without it).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@damienmoon.sh

# Nova DOT LLM backend (the `/nova` admin command). Set NOVA_LLM_URL to enable
# `/nova` (admins chat with the LLM-backed Nova DOT in any channel); leave it
# blank/unset to disable `/nova` — the `/novasay` manual command still works.
# The model is the local Qwen "llama-chat" (llama.cpp, OpenAI-compatible). On
# novahome (prod + test deck) it runs on the SAME host at :8091, so the URL is
# loopback. Local dev has no model — keep this blank.
#NOVA_LLM_URL=http://localhost:8091/v1/chat/completions
# Model tag/path (the single-model llama.cpp server is lenient about this).
#NOVA_LLM_MODEL=/models/Qwen3.6-27B-abliterated-rMAX.i1-Q3_K_M.gguf
# Request timeout (a 27B model on the GPU can take many seconds).
#NOVA_LLM_TIMEOUT_SECS=120
# Reply length cap (tokens) — bounds latency + the 8192-token-per-slot context.
#NOVA_LLM_MAX_TOKENS=768
# How many recent channel messages Nova reads as context per reply.
#NOVA_CONTEXT_MESSAGES=24
# Optional: override Nova DOT's system prompt / voice.
#NOVA_LLM_SYSTEM_PROMPT=
# Tool-calling loop knobs (only relevant when CTX_NOVA_MEMORY_KEY enables ctx tools).
# Max model↔tool round-trips before a tools-disabled squeeze; 0 = never offer tools
# (the plain-chat kill-switch).
#NOVA_TOOL_ITERS=4
# Per-tool-result char cap fed back into the model context.
#NOVA_TOOL_RESULT_MAX_CHARS=3000
# Wall-clock budget (seconds) for the whole reply (the tool loop + every model call).
#NOVA_REPLY_BUDGET_SECS=240

# Nova DOT ctx tools (the knowledge-store bridge). Set CTX_NOVA_MEMORY_KEY to
# give Nova the model-driven ctx tool surface (query/search/get/recent/store) —
# the SAME tools Claude Code uses; leave it blank/unset to disable tools (Nova's
# reply is then a single tools-less model call). The key is a non-admin ctx
# SERVICE key bound to the `nova` scope (mint with `ctx keys create nova-memory
# --home nova`); reads see the `nova` + `shared` scopes, writes pin to `nova`. It
# is sent as the X-Context-Key header. On novahome (prod + test deck) ctx runs on
# the SAME host, so the base URL is loopback. NEVER commit a real key value here.
#CTX_NOVA_MEMORY_KEY=
# ctx base URL — the client POSTs MCP JSON-RPC to `{CTX_BASE_URL}/mcp` (loopback,
# plaintext: reqwest is built without a TLS feature; same MCP server/data as the
# public https://ctx.damienmoon.sh/mcp).
#CTX_BASE_URL=http://127.0.0.1:8080
# Per-tool-call request timeout (kept short — a slow ctx must not stall a reply).
#CTX_TIMEOUT_SECS=10
