SURREAL_URL=ws://127.0.0.1:8000
SURREAL_NS=authlyn
SURREAL_DB=dev
SURREAL_USER=root
SURREAL_PASS=root

# Web Push (#30 background notifications). Generate a keypair ONCE with:
#   npx web-push generate-vapid-keys
# Both values are base64url-unpadded; the public key doubles as the browser's
# applicationServerKey. VAPID_SUBJECT must be a mailto: or https: URL. Leave the
# keys blank to disable push entirely (the app runs fine without it).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@damienmoon.sh
