#!/usr/bin/env bash
# Git pre-commit hook — runs the project check gate (scripts/precommit.sh).
# Wired via: git config core.hooksPath .githooks   (one-time, repo-local)
# Bypass for WIP commits with: git commit --no-verify

set -euo pipefail

exec "$(git rev-parse --show-toplevel)/scripts/precommit.sh"
