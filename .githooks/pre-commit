#!/usr/bin/env bash
# Git pre-commit gate. Opt-in (off by default) — enable per-clone with:
#   git config core.hooksPath .githooks
# Bypass a WIP commit with: git commit --no-verify
set -euo pipefail

# Make the rustup toolchain visible even in non-login shells / GUI clients.
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

cargo fmt --all --check
cargo clippy --features ssr --no-deps -- -D warnings
cargo clippy --features hydrate --target wasm32-unknown-unknown --no-deps -- -D warnings
