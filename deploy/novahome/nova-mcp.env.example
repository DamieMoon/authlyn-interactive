# Nova MCP bridge config. Copy to /opt/nova-mcp/.env on novahome and set a real
# NOVA_PASSWORD (the "Nova" account is auto-created on first start if missing).
NOVA_AUTHLYN_URL=http://127.0.0.1:8081
NOVA_USERNAME=Nova
NOVA_PASSWORD=change-me
NOVA_BIND=127.0.0.1:8082
# tracing verbosity for the bridge
RUST_LOG=info
