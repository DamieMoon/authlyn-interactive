# Production .env for /opt/authlyn/.env on novahome.
# Copy on bootstrap; never commit a populated copy.

# --- SurrealDB ---
# root/root is the v1 placeholder (same as the Pi); scoped creds land with auth.
SURREAL_URL=ws://127.0.0.1:8000
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=authlyn
SURREAL_DB=prod

# --- Leptos runtime ---
# get_configuration(None) in main.rs reads these from the environment. Caddy
# reverse-proxies public :8444 -> 127.0.0.1:8081; the bundle lives at
# /opt/authlyn/site/.
LEPTOS_OUTPUT_NAME=authlyn-interactive
LEPTOS_SITE_ROOT=site
LEPTOS_SITE_PKG_DIR=pkg
LEPTOS_SITE_ADDR=127.0.0.1:8081

# --- Media ---
# main.rs reads MEDIA_STORAGE_DIR (default ./media). On novahome attachments
# live on the dedicated /data volume; authlyn.service grants
# ReadWritePaths=/data/authlyn/media.
MEDIA_STORAGE_DIR=/data/authlyn/media
