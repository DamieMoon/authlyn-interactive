# authlyn-interactive on novahome — standalone Caddy config (/etc/caddy/Caddyfile).
#
# Caddy here terminates TLS on :8444 for authlyn.tplinkdns.com using the
# Let's Encrypt cert that is MINTED AND RENEWED ON THE PI. novahome cannot run
# ACME for this hostname because public :80 (HTTP-01) and :443 (TLS-ALPN-01)
# both route to the Pi (xray on 443, Caddy on 80). The Pi keeps the cert alive
# because a co-hosted Discord-activity site still serves the same hostname (:8443).
# The cert is synced into /var/lib/caddy/authlyn-cert/ (caddy-readable). Explicit `tls`
# => Caddy makes no ACME attempt for this site.
#
# Router: external :8444 -> novahome:8444 (set by Damien 2026-05-25).

{
	# No ACME, no HTTP->HTTPS redirect. This box only serves explicit-cert
	# HTTPS on :8444; :80 is not forwarded here (it stays with the Pi).
	auto_https off
}

authlyn.tplinkdns.com:8444 {
	tls /var/lib/caddy/authlyn-cert/authlyn.tplinkdns.com.crt /var/lib/caddy/authlyn-cert/authlyn.tplinkdns.com.key

	encode zstd gzip
	reverse_proxy 127.0.0.1:8081

	header {
		-Server
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
	}

	log {
		output file /var/log/caddy/authlyn-interactive.log
		format console
	}
}
