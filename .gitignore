# Cargo build artefacts. `target/` also holds the cargo-leptos site output
# (Cargo.toml sets site-root = "target/site", site-pkg-dir = pkg under it),
# so the compiled WASM/JS/CSS bundle needs no separate rule.
debug/
target/

# rustfmt backup files
**/*.rs.bk

# MSVC Windows builds
*.pdb

# Local env / secrets. `.env.example` is TRACKED (the `cp .env.example .env`
# workflow), so do NOT broaden these to `.env*` or the example gets ignored.
.env
.env.local

# macOS
.DS_Store

# SurrealDB CLI command-history file (dropped where the CLI was invoked).
history.txt

# Per-machine Claude notes (deployment IPs, SSH key names, etc.)
CLAUDE.local.md

# Media storage root (dev default). `main.rs` creates this at startup when
# `$MEDIA_STORAGE_DIR` is unset; production points MEDIA_STORAGE_DIR elsewhere,
# so the in-repo path is dev-only and never committed.
/media/

# Claude Code config — INTENTIONAL whitelist: ignore everything under .claude/
# (harness agent worktrees, settings.json + settings.local.json, plugin caches,
# etc.) and re-include ONLY the shared project slash-commands. settings.json is
# machine-local (Bash allowlist lives in the global ~/.claude/settings.json) and
# is NOT tracked. To share another .claude/ file later (a command, agent, or
# skill), add an explicit `!` negation below.
/.claude/*
!/.claude/commands/

# Playwright MCP scratch (snapshots, fixtures, screenshots) — never commit
.playwright-mcp/

# Visual gate (dev-only headed-Playwright orbit regression net, visual-gate/):
# its npm deps and per-run screenshots are local junk, never committed. The
# harness sources (package.json, *.mjs, README) ARE tracked.
visual-gate/node_modules/
visual-gate/shots/

# Stray gate-capture screenshots that land in the repo ROOT (xengine / fidelity
# captures that escaped their out-dir under ~/authlyn-ios-gate). Root-level PNGs
# are always junk here — real images live under public/ or docs/. Root-only
# (leading slash), so public/*.png and docs/**/*.png stay tracked.
/*.png
