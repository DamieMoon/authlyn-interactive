# Cargo build artefacts
debug/
target/

# Claude Code: ignore the local-only bits (agent worktrees, settings.local.json,
# agents/) but commit the shared settings.json — cloud sessions (Claude Code web)
# only see committed files, and need its SessionStart hook to start SurrealDB.
/.claude/*
!/.claude/settings.json

# rustfmt backup files
**/*.rs.bk

# MSVC Windows builds
*.pdb

# Local env / secrets
.env
.env.local
deploy/.env
deploy/.github_token

# macOS
.DS_Store

# SurrealDB CLI command-history file (dropped where the CLI was invoked).
history.txt

# Per-machine Claude notes (deployment IPs, SSH key names, etc.)
CLAUDE.local.md

# Encrypted-attachment storage root (dev default). `main.rs` creates this
# at startup if `$MEDIA_STORAGE_DIR` is unset; on the Pi the dir lives at
# `/opt/authlyn/media` so the in-repo path is dev-only.
/media/
